{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
            "-fdiagnostics-color=always",
            "-g",
            "${workspaceFolder}/main.cpp", // 오직 메인만!
            "-I${workspaceFolder}",        // 루트를 인클루드 경로로 설정
            "-o",
            "${workspaceFolder}/build/Debug/outDebug"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}